Constructor Integer/Integer:RationalNumber

Type NonZeroInteger

Variables p,q:RationalNumber

Axiom (RationalNumbersAreIntegersDividedByNonZeroIntegers)
  Suppose
    p:Integer
    q:NonZeroInteger
  Hence
    p/q = p ÷ q

# This needs to be fixed, the duplicate label is not working properly.
Axiom (PredecessorsOfSuccessorsNaturalNumbers)
  Suppose
    n:NaturalNumber
  Hence
    predecessor(successor(n)) = n
